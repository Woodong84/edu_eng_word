rules_version = '2';
// Firebase 콘솔에서 직접 배포하는 파일입니다 (Firestore Database > 규칙 탭에 이 내용을 붙여넣고 게시).
// 이 저장소에는 소스 기록용으로만 보관하며, 이 파일을 커밋한다고 자동으로 배포되지 않습니다.
//
// 신뢰 경계: 이 앱은 불특정 다수를 대상으로 하는 서비스가 아니라 가족 단위로 사용하는
// 개인 프로젝트입니다. 그래서 프로필 간 소유권을 엄격히 분리하지 않고, "로그인된 사람(가족)"
// 전체를 하나의 신뢰 그룹으로 취급합니다 — 기존 localStorage 방식(이 기기에 접근 가능한
// 사람 = 전체 접근 가능)과 동일한 신뢰 수준입니다. 마스터 단어 데이터만 이메일 계정으로
// 로그인한 관리자에게 쓰기 권한을 제한합니다.
service cloud.firestore {
  match /databases/{database}/documents {

    match /profiles/{profileId} {
      allow read, write: if request.auth != null;

      match /words/{wordId} {
        allow read, write: if request.auth != null;
      }
      match /folders/{folderId} {
        allow read, write: if request.auth != null;
      }
      match /history/{historyId} {
        allow read, write: if request.auth != null;
      }
    }

    match /masterWords/{wordId} {
      allow read: if request.auth != null;
      // 익명 계정(token.email 없음)은 읽기만 가능, 이메일/비밀번호로 로그인한 관리자만 쓰기 가능
      allow write: if request.auth != null && request.auth.token.email != null;
    }
  }
}
